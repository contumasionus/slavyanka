# База данных (SQLite по умолчанию)
DATABASE_URL=file:./dev.db

# Секретный ключ для JWT (изменить в продакшене!)
JWT_SECRET=slavyanka-super-secret-key-2026

# Порт сервера (по умолчанию 3001)
PORT=3001

# Хост сервера
HOST=0.0.0.0

# EmailJS — отправка писем с кодом подтверждения
# Если не указывать — будут использованы встроенные ключи (работают из коробки)
# Чтобы сменить почту: зарегистрируйтесь на emailjs.com и впишите свои ключи
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=